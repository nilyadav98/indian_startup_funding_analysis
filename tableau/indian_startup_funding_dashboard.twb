    <worksheet name='Top Investors'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='10'>Top 15 Most Active Investors (2014–2019)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='funding_clean' name='federated.1vbl98z05if4lo1gnnsnq0yel9kz' />
          </datasources>
          <datasource-dependencies datasource='federated.1vbl98z05if4lo1gnnsnq0yel9kz'>
            <column caption='Is Real Investor' datatype='boolean' name='[Calculation_1597651727925248]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT CONTAINS(LOWER([investors]), &quot;undisclosed&quot;)&#13;&#10;AND NOT CONTAINS(LOWER([investors]), &quot;angel investor&quot;)&#13;&#10;AND [investors] != &quot;nan&quot;&#13;&#10;AND [investors] != &quot;&quot;' />
            </column>
            <column-instance column='[__tableau_internal_object_id__].[funding_clean.csv_B1C86FA9BD6B45FB982E57AC34F075DE]' derivation='Count' name='[__tableau_internal_object_id__].[cnt:funding_clean.csv_B1C86FA9BD6B45FB982E57AC34F075DE:qk]' pivot='key' type='quantitative' />
            <column caption='funding_clean.csv' datatype='table' name='[__tableau_internal_object_id__].[funding_clean.csv_B1C86FA9BD6B45FB982E57AC34F075DE]' role='measure' type='quantitative' />
            <column caption='Investors' datatype='string' name='[investors]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1597651727925248]' derivation='None' name='[none:Calculation_1597651727925248:nk]' pivot='key' type='nominal' />
            <column-instance column='[investors]' derivation='None' name='[none:investors:nk]' pivot='key' type='nominal' />
            <column-instance column='[year]' derivation='None' name='[none:year:qk]' pivot='key' type='quantitative' />
            <column caption='Year' datatype='integer' name='[year]' role='dimension' type='quantitative' />
