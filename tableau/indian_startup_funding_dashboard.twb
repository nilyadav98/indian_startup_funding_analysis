          <filter class='categorical' column='[federated.1vbl98z05if4lo1gnnsnq0yel9kz].[none:Calculation_1597651727925248:nk]'>
            <groupfilter function='member' level='[none:Calculation_1597651727925248:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1vbl98z05if4lo1gnnsnq0yel9kz].[none:investors:nk]'>
